          "iv": "AQEBAQEBAQEBAQEBAQEBAQ==",
          "tag": "xYz3aBcDeF1gHiJkLmNoPq==",
          "algorithm": "A128CBC-HS256",
          "recipient_key_id": "key-worker-2026-03"
        }
      },
      "note": "A128CBC-HS256 uses AES-CBC with HMAC-SHA-256 for authentication."
    },
    {
      "description": "EncryptedBody standalone — A256GCM with long ciphertext",
