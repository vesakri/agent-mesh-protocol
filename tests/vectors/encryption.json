    {
      "description": "Decrypted envelope — plaintext body after decryption",
      "body_type": "task.create",
      "valid": true,
      "envelope": {
        "sender": "agent://requester.example.com",
        "recipient": "agent://executor.example.com",
        "body_type": "task.create",
        "headers": {
          "Protocol-Version": "0.1.9",
          "Session-Id": "sess-enc-001"
        },
        "body": {
          "description": "Find the nearest available courier",
          "priority": "high",
          "tools_required": ["routing", "dispatch"],
          "timeout_seconds": 120
        }
      },
      "note": "After decryption, the Content-Encryption header is removed and the body contains the original typed payload."
    },
