{
  "description": "Test vectors for EncryptedBody and Content-Encryption header (AMP v0.1.9). Covers A256GCM and A128CBC-HS256 algorithms, envelope wrapping, and invalid payloads.",
  "vectors": [
    {
      "description": "Encrypted envelope — A256GCM algorithm",
      "body_type": "message",
      "valid": true,
      "envelope": {
        "sender": "agent://requester.example.com",
        "recipient": "agent://executor.example.com",
        "body_type": "message",
        "headers": {
          "Protocol-Version": "0.1.9",
          "Session-Id": "sess-enc-001",
          "Content-Encryption": "A256GCM"
        },
        "body": {
          "ciphertext": "dGhpcyBpcyBhIHNpbXVsYXRlZCBjaXBoZXJ0ZXh0IGJsb2I=",
          "iv": "AAAAAAAAAAAAAAAAAAAAAA==",
          "tag": "kMbTHlCzQ3GP9v7NrF2xYQ==",
          "algorithm": "A256GCM",
          "recipient_key_id": "key-executor-2026-04"
        }
      },
      "note": "When Content-Encryption header is present, body contains EncryptedBody instead of the typed body payload."
    },
    {
      "description": "Encrypted envelope — A128CBC-HS256 algorithm",
      "body_type": "task.create",
