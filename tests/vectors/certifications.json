{
  "description": "Test vectors for CertificationLink in agent.json (AMP v0.1.9). Covers SOC2, ISO27001, multiple certifications, empty list, and invalid payloads.",
  "vectors": [
    {
      "description": "agent.json with SOC2 + ISO27001 certifications",
      "test_type": "agent_json",
      "valid": true,
      "agent_json": {
        "protocol_version": "0.1.9",
        "identifiers": ["agent://service.example.com"],
        "endpoint": "https://service.example.com/agent/message",
        "status": "active",
        "certifications": [
          {
            "standard": "SOC2",
            "url": "https://auditor.example.com/certs/service-soc2-2026.pdf",
            "verified_by": "agent://auditor.example.com",
            "expires_at": "2027-04-09T00:00:00Z"
          },
          {
            "standard": "ISO27001",
            "url": "https://auditor.example.com/certs/service-iso27001-2026.pdf",
            "verified_by": "agent://auditor.example.com",
            "expires_at": "2027-06-01T00:00:00Z"
          }
        ],
        "capabilities": {
          "groups": ["task", "data"],
          "level": 3
        }
      },
      "note": "Agent advertising both SOC2 and ISO27001 certifications. Callers can inspect these before delegating sensitive work."
    },
    {
      "description": "agent.json with single GDPR certification",
      "test_type": "agent_json",
      "valid": true,
      "agent_json": {
        "protocol_version": "0.1.9",
