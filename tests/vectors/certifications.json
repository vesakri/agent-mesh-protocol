        "endpoint": "https://eu-service.example.com/agent/message",
        "status": "active",
        "certifications": [
          {
            "standard": "GDPR",
            "url": "https://dpa.example.eu/certs/eu-service-gdpr-2026.pdf",
            "verified_by": "agent://dpa.example.eu",
            "expires_at": "2027-01-15T00:00:00Z"
          }
        ],
        "capabilities": {
          "groups": ["task"],
          "level": 2
        }
      },
      "note": "EU-based agent with GDPR compliance certification."
    },
    {
      "description": "agent.json with empty certifications array",
      "test_type": "agent_json",
      "valid": true,
      "agent_json": {
        "protocol_version": "0.1.9",
        "identifiers": ["agent://basic.example.com"],
        "endpoint": "https://basic.example.com/agent/message",
        "status": "active",
        "certifications": [],
