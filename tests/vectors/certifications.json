        "protocol_version": "0.1.9",
        "identifiers": ["agent://minimal.example.com"],
        "endpoint": "https://minimal.example.com/agent/message",
        "status": "active",
        "capabilities": {
          "groups": [],
          "level": 0
        }
      },
      "note": "Minimal agent.json omitting certifications entirely. The field defaults to an empty list."
    },
    {
      "description": "Valid CertificationLink — SOC2 standalone",
      "valid": true,
      "certification": {
        "standard": "SOC2",
        "url": "https://auditor.example.com/certs/agent-soc2-2026.pdf",
        "verified_by": "agent://auditor.example.com",
        "expires_at": "2027-04-09T00:00:00Z"
      }
    },
