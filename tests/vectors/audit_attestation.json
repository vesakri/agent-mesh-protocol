      "body_type": "audit.attestation",
      "valid": false,
      "expected_error": "attestation_signatures",
      "body": {
        "audit_id": "att-bad-003",
        "agents": [
          "agent://a.example.com",
          "agent://b.example.com"
        ],
        "events_hash": "abcdef1234567890",
        "timestamp": "2026-04-09T12:00:00Z"
      }
    },
    {
